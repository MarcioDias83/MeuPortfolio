  <!-- BACK TO TOP -->
  <button class="back-to-top" id="backToTop" aria-label="Voltar ao topo">
    <i class="fas fa-chevron-up"></i>
  </button>

  <!-- PARTICLE BACKGROUND -->
  <canvas id="particle-canvas"></canvas>

  <script>
    // ===== PRELOADER =====
    const preloader = document.getElementById('preloader');
    window.addEventListener('load', () => {
      setTimeout(() => preloader.classList.add('hidden'), 800);
    });

    // ===== NAV TOGGLE =====
    const navToggle = document.getElementById('navToggle');
    const navLinks = document.getElementById('navLinks');
    navToggle.addEventListener('click', () => {
      navToggle.classList.toggle('active');
      navLinks.classList.toggle('open');
    });
    document.querySelectorAll('.nav-links a').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('open');
        navToggle.classList.remove('active');
      });
    });

    // ===== ACTIVE NAV LINK ON SCROLL =====
    const sections = document.querySelectorAll('section[id]');
    const navAnchors = document.querySelectorAll('.nav-links a');
    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(section => {
        const top = section.offsetTop - 120;
        if (window.scrollY >= top) current = section.getAttribute('id');
      });
      navAnchors.forEach(a => {
        a.classList.toggle('active', a.getAttribute('href') === '#' + current);
      });
    });

    // ===== STAGGERED FADE-UP WITH INTERSECTION OBSERVER =====
    const fadeObserver = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), 80);
          fadeObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    document.querySelectorAll('.fade-up, .scale-in').forEach(el => fadeObserver.observe(el));

    // ===== STAT COUNTERS =====
    const numObserver = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const el = e.target;
          const target = parseInt(el.dataset.target);
          if (!target) return;
          let cur = 0;
          const inc = Math.ceil(target / 40);
          const t = setInterval(() => {
            cur += inc;
            if (cur >= target) { cur = target; clearInterval(t); }
            el.textContent = cur;
          }, 30);
          numObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-target]').forEach(el => numObserver.observe(el));

    // ===== BACK TO TOP =====
    const backBtn = document.getElementById('backToTop');
    window.addEventListener('scroll', () => {
      backBtn.classList.toggle('visible', window.scrollY > 500);
    });
    backBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    // ===== PARTICLE SYSTEM + GRADIENT ORBS + MOUSE PARALLAX =====
    const canvas = document.getElementById('particle-canvas');
    const ctx = canvas.getContext('2d');
    let W, H;

    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    // Mouse tracking
    const mouse = { x: -9999, y: -9999, px: -9999, py: -9999 };
    document.addEventListener('mousemove', e => {
      mouse.px = mouse.x;
      mouse.py = mouse.y;
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });
    document.addEventListener('mouseleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    // Touch support
    document.addEventListener('touchmove', e => {
      const t = e.touches[0];
      mouse.x = t.clientX;
      mouse.y = t.clientY;
    }, { passive: true });
    document.addEventListener('touchend', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    // ---- GRADIENT ORBS ----
    const orbs = [];
    const ORB_COUNT = 4;
    for (let i = 0; i < ORB_COUNT; i++) {
      orbs.push({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.2,
        vy: (Math.random() - 0.5) * 0.2,
        r: 200 + Math.random() * 300,
        alpha: 0.03 + Math.random() * 0.04,
        hue: 210 + Math.random() * 40,
        phase: Math.random() * Math.PI * 2,
      });
    }

    // ---- PARTICLES ----
    const particles = [];
    const PARTICLE_COUNT = 120;

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: 1 + Math.random() * 2.5,
        baseAlpha: 0.2 + Math.random() * 0.5,
        alpha: 0,
        phase: Math.random() * Math.PI * 2,
        pulseSpeed: 0.005 + Math.random() * 0.015,
        layer: Math.random(), // 0-1 for parallax depth
      });
    }

    // ---- SCROLL PARALLAX ----
    let scrollY = 0;
    window.addEventListener('scroll', () => {
      scrollY = window.scrollY;
    }, { passive: true });

    // ---- DRAW LOOP ----
    let animTime = 0;

    function drawParticles() {
      ctx.clearRect(0, 0, W, H);
      animTime += 0.008;

      // 1. Gradient orbs
      for (const orb of orbs) {
        orb.x += orb.vx + Math.sin(animTime * 0.1 + orb.phase) * 0.1;
        orb.y += orb.vy + Math.cos(animTime * 0.08 + orb.phase) * 0.1;

        if (orb.x < -orb.r) orb.x = W + orb.r;
        if (orb.x > W + orb.r) orb.x = -orb.r;
        if (orb.y < -orb.r) orb.y = H + orb.r;
        if (orb.y > H + orb.r) orb.y = -orb.r;

        const gradient = ctx.createRadialGradient(orb.x, orb.y, 0, orb.x, orb.y, orb.r);
        const pulse = 0.7 + 0.3 * Math.sin(animTime * 0.02 + orb.phase);
        gradient.addColorStop(0, `hsla(${orb.hue}, 80%, 60%, ${orb.alpha * pulse})`);
        gradient.addColorStop(0.4, `hsla(${orb.hue + 20}, 70%, 40%, ${orb.alpha * pulse * 0.5})`);
        gradient.addColorStop(1, `hsla(${orb.hue + 40}, 60%, 20%, 0)`);

        ctx.fillStyle = gradient;
        ctx.fillRect(orb.x - orb.r, orb.y - orb.r, orb.r * 2, orb.r * 2);
      }

      // 2. Scroll parallax offset
      const parallaxOffset = scrollY * -0.15;

      // 3. Update & draw particles
      const mouseRadius = 120;
      const mouseForce = 0.6;

      for (const p of particles) {
        // Pulse brightness
        p.alpha = p.baseAlpha * (0.6 + 0.4 * Math.sin(animTime * p.pulseSpeed + p.phase));

        // Mouse repulsion
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < mouseRadius && dist > 0) {
          const force = (mouseRadius - dist) / mouseRadius * mouseForce;
          const angle = Math.atan2(dy, dx);
          p.vx += Math.cos(angle) * force;
          p.vy += Math.sin(angle) * force;
        }

        // Mouse attraction to create connections near cursor
        if (dist < mouseRadius * 1.5 && dist > 0) {
          // gentle pull toward cursor's previous position creates trails
          const pull = 0.02;
          p.vx += (mouse.x - mouse.px) * pull * (1 - dist / (mouseRadius * 1.5));
          p.vy += (mouse.y - mouse.py) * pull * (1 - dist / (mouseRadius * 1.5));
        }

        // Damping
        p.vx *= 0.98;
        p.vy *= 0.98;

        // Clamp speed
        const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (speed > 2) {
          p.vx = (p.vx / speed) * 2;
          p.vy = (p.vy / speed) * 2;
        }

        p.x += p.vx;
        p.y += p.vy;

        // Wrap around edges
        if (p.x < -20) p.x = W + 20;
        if (p.x > W + 20) p.x = -20;
        if (p.y < -20) p.y = H + 20;
        if (p.y > H + 20) p.y = -20;

        // Draw particle with parallax
        const px = p.x;
        const py = p.y + parallaxOffset * p.layer;
        const scrollFade = Math.max(0, Math.min(1, (py + 100) / 200)) *
                           Math.max(0, Math.min(1, (H - py + 100) / 200));
        const alpha = p.alpha * scrollFade;

        ctx.beginPath();
        ctx.arc(px, py, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(100, 180, 255, ${alpha * 0.6})`;
        ctx.fill();

        // Glow dot
        if (p.r > 1.5) {
          const glow = ctx.createRadialGradient(px, py, 0, px, py, p.r * 4);
          glow.addColorStop(0, `rgba(66, 165, 245, ${alpha * 0.08})`);
          glow.addColorStop(1, 'rgba(66, 165, 245, 0)');
          ctx.fillStyle = glow;
          ctx.fillRect(px - p.r * 4, py - p.r * 4, p.r * 8, p.r * 8);
        }
      }

      // 4. Dynamic connections between particles
      const connectDist = 100;
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const a = particles[i];
          const b = particles[j];
          const dx = a.x - b.x;
          const dy = (a.y + parallaxOffset * a.layer) - (b.y + parallaxOffset * b.layer);
          const d = Math.sqrt(dx * dx + dy * dy);

          if (d < connectDist) {
            const alpha = (1 - d / connectDist) * 0.12;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y + parallaxOffset * a.layer);
            ctx.lineTo(b.x, b.y + parallaxOffset * b.layer);
            ctx.strokeStyle = `rgba(66, 165, 245, ${alpha})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      // 5. Mouse connection lines (temporary, near cursor)
      const mouseConnectRadius = 150;
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        const px = p.x;
        const py = p.y + parallaxOffset * p.layer;
        const dx = px - mouse.x;
        const dy = py - mouse.y;
        const d = Math.sqrt(dx * dx + dy * dy);

        if (d < mouseConnectRadius) {
          const alpha = (1 - d / mouseConnectRadius) * 0.2;
          ctx.beginPath();
          ctx.moveTo(mouse.x, mouse.y);
          ctx.lineTo(px, py);
          ctx.strokeStyle = `rgba(66, 165, 245, ${alpha})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();

          // Connect nearby particles near mouse
          for (let j = i + 1; j < particles.length; j++) {
            const q = particles[j];
            const qx = q.x;
            const qy = q.y + parallaxOffset * q.layer;
            const dx2 = qx - mouse.x;
            const dy2 = qy - mouse.y;
            const d2 = Math.sqrt(dx2 * dx2 + dy2 * dy2);
            if (d2 < mouseConnectRadius) {
              const dx3 = px - qx;
              const dy3 = py - qy;
              const d3 = Math.sqrt(dx3 * dx3 + dy3 * dy3);
              if (d3 < connectDist) {
                const a2 = (1 - d / mouseConnectRadius) * (1 - d2 / mouseConnectRadius) * 0.25;
                ctx.beginPath();
                ctx.moveTo(px, py);
                ctx.lineTo(qx, qy);
                ctx.strokeStyle = `rgba(100, 200, 255, ${a2})`;
                ctx.lineWidth = 0.5;
                ctx.stroke();
              }
            }
          }
        }
      }

      requestAnimationFrame(drawParticles);
    }

    // Handle resize for orbs
    window.addEventListener('resize', () => {
      for (const orb of orbs) {
        if (orb.x > W) orb.x = W * 0.8;
        if (orb.y > H) orb.y = H * 0.8;
      }
    });

    drawParticles();
  </script>
</body>
</html>
